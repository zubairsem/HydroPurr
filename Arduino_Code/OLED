#include <U8g2lib.h>
#include <Wire.h>

// OLED 0.96 inch SSD1306
// Connection:
// OLED SCL -> D6
// OLED SDA -> D7
U8G2_SSD1306_128X64_NONAME_F_SW_I2C oled(
  U8G2_R0,
  D6,   // SCL
  D7,   // SDA
  U8X8_PIN_NONE
);

void setup() {
  oled.begin();

  oled.clearBuffer();
  oled.setFont(u8g2_font_6x10_tf);
  oled.drawStr(0, 15, "OLED TEST");
  oled.drawStr(0, 35, "SCL = D6");
  oled.drawStr(0, 50, "SDA = D7");
  oled.sendBuffer();
}

void loop() {
  // Nothing needed here
}
